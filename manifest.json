{
    "manifestVersion": 2,
    "id"            : "kilroy.starter.agent",
    "displayName"   : "Kilroy Starter (Agent)",
    "desc"          : "Multi-class starter app template with chat agent UI",
    "version"       : "1.0",
    "author"        : "Kilroy BC, LLC",
    "authorInfoUrl" : "http://kilroy.tech",
    "appInfoUrl"    : "/apps/kilroy.starter.agent/info.html",
    "appImageUrl"   : "/apps/kilroy.starter.agent/images/logo.png",
    "locked"        : false,
    "override"      : false,
    "hidden"        : false,
    "pdClasses"     : {
        "manager"    : {
            "pdName" : "manager",
            "pdAlias": "kilroy.starter.agent.manager",
            "desc"  : "Starter Agent App Manager",
            "runOnStart": true,
            "visible": true,
            "multipleAllowed": false,
            "init"  : "init_hook",
            "resume": "resume_hook",
            "pause" : "pause_hook",
            "stop"  : "stop_hook"
        },
        "chat_agent"    : {
            "pdName" : "chat_agent",
            "pdAlias": "kilroy.starter.agent.chat_agent",
            "desc"  : "Starter App Chat Agent",
            "runOnStart": false,
            "visible": true,
            "multipleAllowed": true,
            "init"  : "init_hook",
            "resume": "resume_hook",
            "pause" : "pause_hook",
            "stop"  : "stop_hook"
        }
    }
}